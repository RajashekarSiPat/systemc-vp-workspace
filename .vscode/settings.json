{
    // ── C++ / clangd ──────────────────────────────────────────────────────────
    // Use clangd instead of the default IntelliSense engine.
    // clangd reads compile_commands.json so it resolves all QBOX headers.
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build",
        "--background-index",
        "--clang-tidy",
        "--header-insertion=never",
        "--completion-style=detailed",
        "--log=error"
    ],
    "C_Cpp.intelliSenseEngine": "disabled",

    // ── CMake Tools ───────────────────────────────────────────────────────────
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.sourceDirectory": "${workspaceFolder}",
    "cmake.configureArgs": [
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
    ],
    "cmake.copyCompileCommands": "${workspaceFolder}/build/compile_commands.json",

    // ── Editor ────────────────────────────────────────────────────────────────
    "editor.formatOnSave": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": true,

    // ── File associations ─────────────────────────────────────────────────────
    "files.associations": {
        "*.h":   "cpp",
        "*.cc":  "cpp",
        "*.cpp": "cpp",
        "*.lua": "lua"
    },

    // ── Exclude build noise from file explorer ────────────────────────────────
    "files.exclude": {
        "build/":            true,
        "qbox/":             true,
        "**/*.so":           true,
        "**/*.o":            true,
        "**/*.elf":          true,
        "**/.cache":         true,
        "**/CMakeFiles":     true,
        "**/CMakeCache.txt": true
    }
}

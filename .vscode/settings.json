{
    // ── CMake Tools ───────────────────────────────────────────────────────────
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.sourceDirectory": "${workspaceFolder}",
    "cmake.configureArgs": [
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
    ],
    "cmake.copyCompileCommands": "${workspaceFolder}/build/compile_commands.json",

    // ── Editor ────────────────────────────────────────────────────────────────
    "editor.formatOnSave": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": true,

    // ── Vim (vscodevim) ───────────────────────────────────────────────────────
    "vim.enable": true,
    "vim.useSystemClipboard": true,
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.useCtrlKeys": true,
    "vim.leader": "<Space>",
    "vim.normalModeKeyBindingsNonRecursive": [
        { "before": ["<leader>", "f"], "commands": ["workbench.action.quickOpen"] },
        { "before": ["<leader>", "g"], "commands": ["workbench.action.findInFiles"] },
        { "before": ["<leader>", "b"], "commands": ["workbench.action.showAllEditors"] },
        { "before": ["g", "d"],        "commands": ["editor.action.revealDefinition"] },
        { "before": ["g", "r"],        "commands": ["editor.action.goToReferences"] },
        { "before": ["K"],             "commands": ["editor.action.showHover"] }
    ],

    // ── File associations ─────────────────────────────────────────────────────
    "files.associations": {
        "*.h":   "cpp",
        "*.cc":  "cpp",
        "*.cpp": "cpp",
        "*.lua": "lua"
    },

    // ── Exclude build noise from file explorer ────────────────────────────────
    "files.exclude": {
        "build/":            true,
        "qbox/":             true,
        "**/*.so":           true,
        "**/*.o":            true,
        "**/*.elf":          true,
        "**/.cache":         true,
        "**/CMakeFiles":     true,
        "**/CMakeCache.txt": true
    }
}
